# ─── Backend Environment Variables (.env) ────────────────────────────────────
# Copy this file to .env and fill in your values for local development.
# On Render, set these under the service's "Environment" tab.

# Django
DJANGO_SECRET_KEY=your-very-secret-key-here-change-this
DJANGO_DEBUG=True
# Space-separated list of allowed hostnames.
# Local dev: leave empty (defaults to localhost & 127.0.0.1)
# Render: e.g.  your-app.onrender.com
DJANGO_ALLOWED_HOSTS=

# Database
# Leave blank locally to use SQLite.
# Render injects this automatically from the attached PostgreSQL database.
DATABASE_URL=

# CORS – Space-separated list of allowed origins for the frontend.
# Local dev: already includes http://localhost:5173 by default.
# Render: add your Vercel URL, e.g.  https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=

# CSRF – Comma-separated trusted origins (required by Django 4+ for secure cookies).
# e.g.  https://your-app.onrender.com https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=

# JWT token lifetimes (optional)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# DRF pagination / throttling (optional)
DRF_PAGE_SIZE=100
DRF_THROTTLE_USER=1000/hour
DRF_THROTTLE_ANON=100/hour
