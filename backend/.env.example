# ==============================================
# Backend Environment Configuration
# ==============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ==============================================

# Server
NODE_ENV=development
PORT=5001

# Database Configuration (PostgreSQL)
# Option 1: Cloud PostgreSQL connection string (Neon, Supabase, Railway, Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Option 2: Individual vars for local development
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=construction_tracker
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password

# JWT Configuration
# IMPORTANT: Change this to a strong random secret in production
JWT_SECRET=CHANGE-THIS-TO-A-STRONG-RANDOM-SECRET-KEY
JWT_EXPIRE=7d

# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=https://your-frontend.vercel.app,http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Rate Limiting (15 min window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=15000

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log