# ─── Frontend Environment Variables (.env.local) ─────────────────────────────
# Copy this file to .env.local for local development.
# On Vercel, set these under Project → Settings → Environment Variables.
#
# ⚠️  Vercel env vars must be prefixed with VITE_ to be exposed to the browser.

# Base URL of the backend API (no trailing slash after /api).
# Local dev:  http://127.0.0.1:8000/api
# Production: https://your-render-service.onrender.com/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Base URL for media files served by Django (no trailing slash).
# Local dev:  http://127.0.0.1:8000
# Production: https://your-render-service.onrender.com
VITE_MEDIA_BASE_URL=http://127.0.0.1:8000
